#!/usr/bin/env bash
# This script displays subdomain information for a domain

# Function to get subdomain info
get_subdomain_info() {
    local domain=$1
    local sub=$2
    local result
    result=$(dig +short $sub.$domain)
    echo "The subdomain $sub is a A record and points to $result"
}

# Main
domain=$1
subdomain=$2

if [ -z "$subdomain" ]; then
    for sub in www lb-01 web-01 web-02; do
        get_subdomain_info $domain $sub
    done
else
    get_subdomain_info $domain $subdomain
fi